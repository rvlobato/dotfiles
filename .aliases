alias dotfiles='/usr/bin/git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'
alias gf='gfortran'
alias py='python'
alias sudo='run0 --background= '

alias noton="makoctl mode -r do-not-disturb"
alias notoff="makoctl mode -a do-not-disturb"

alias myip='curl ipinfo.io/ip'
alias hibernate='systemctl hibernate'
alias suspend='systemctl suspend'

alias ex="emacs -Q -nw"
alias emacsclient='emacsclient -nw'

## colors
alias ls="ls --color -F"
alias ll="ls --color -lh"
alias la="ls --color -al"
alias grep='grep --colour=always'
alias egrep='egrep --colour=auto'
alias fgrep='fgrep --colour=auto'
alias dir='dir --color=auto'
alias vdir='vdir --color=auto'

#up: jupyter, npm, pip, rust, R and Julia
alias npmin='npm i -g $(cat $HOME/.config/pkgnpm.txt)'
alias npmup='npm update -g'
alias npmshow='npm -g list --depth=0'
alias carin='cargo install $(cat $HOME/.config/pkgrust.txt)'
alias carup='cargo install-update -a'
alias julin='julia -t auto $HOME/.config/packages.jl'

## git
alias gc='git commit '
alias gsta='git status'
alias gam='git commit --amend '
alias gcm='git checkout master'
alias gfu='git fetch upstream'
alias grm='git rebase -i master '
alias gm='git merge '

## moving in dirs
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."
